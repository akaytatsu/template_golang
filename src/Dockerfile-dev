FROM golang:1.25-bookworm AS base

ENV GO111MODULE="on"
ENV GOOS="linux"
ENV CGO_ENABLED=1
ENV GOWORK=off
ENV GOPROXY=https://proxy.golang.org,direct

# System dependencies
RUN apt-get update && apt-get install -y ca-certificates curl bash gcc wget \
        libc-dev librdkafka-dev pkg-config

# Usar librdkafka do sistema (glibc) em vez da versão estática musl
ENV CGO_CFLAGS="-O2 -g"
ENV CGO_LDFLAGS="-lresolv"
ENV PKG_CONFIG_PATH="/usr/lib/x86_64-linux-gnu/pkgconfig"

# Instalar todas as ferramentas uma única vez
RUN go install gotest.tools/gotestsum@v1.13.0 && \
        go install go.uber.org/mock/mockgen@v0.6.0 && \
        go install github.com/smartystreets/goconvey@v1.8.1 && \
        go install github.com/go-delve/delve/cmd/dlv@v1.27.0 && \
        go install github.com/air-verse/air@v1.65.3 && \
        go install github.com/swaggo/swag/cmd/swag@v1.16.6 && \
        go install golang.org/x/vuln/cmd/govulncheck@v1.4.0

FROM base AS dev
WORKDIR /app

# Copiar apenas go.mod e go.sum primeiro para cache de dependências
COPY go.mod go.sum ./
RUN go mod download

# Depois copiar o resto do código
COPY . .

EXPOSE 8080
EXPOSE 2345

ENTRYPOINT ["/go/bin/air"]
